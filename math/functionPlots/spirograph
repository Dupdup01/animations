#define _USE_MATH_DEFINES
#include <cairo/cairo.h>
#include <cstdio>
#include <cmath>

int main() {
    const int WIDTH = 1920, HEIGHT = 1080;
    const int FRAMES = 240;

    FILE* ffmpeg = _popen(
        "C:/ffmpeg/bin/ffmpeg.exe -y -f rawvideo -pixel_format bgra "
        "-video_size 1920x1080 -framerate 60 "
        "-i pipe:0 -c:v libx264 -pix_fmt yuv420p "
        "C:/Users/chris/OneDrive/Documents/Projects/animation/output_video/output.mp4",
        "wb"
    );

    if (!ffmpeg) {
        fprintf(stderr, "Failed to open FFmpeg pipe\n");
        return 1;
    }

    cairo_surface_t* surface = cairo_image_surface_create(CAIRO_FORMAT_ARGB32, WIDTH, HEIGHT);
    cairo_t* cr = cairo_create(surface);

    // Spirograph parameters
    const double R = 300.0;  // outer circle radius
    const double r = 113.0;  // inner circle radius
    const double d = 250.0;  // pen distance from inner circle center

    for (int frame = 0; frame < FRAMES; frame++) {
        double t = (double)frame / (FRAMES - 1);

        // Ease in-out
        double ease = t < 0.5
            ? 2 * t * t
            : 1 - pow(-2 * t + 2, 2) / 2;

        // How much of the spirograph to draw (grows over time)
        double maxAngle = ease * 2 * M_PI * 7;

        // Clear background
        cairo_set_source_rgb(cr, 0.05, 0.05, 0.12);
        cairo_paint(cr);

        // Draw faint guide circles
        cairo_set_line_width(cr, 1.0);
        cairo_set_source_rgba(cr, 1.0, 1.0, 1.0, 0.08);
        cairo_arc(cr, WIDTH/2.0, HEIGHT/2.0, R, 0, 2*M_PI);
        cairo_stroke(cr);

        // Draw the spirograph path with color cycling
        int steps = (int)(maxAngle / 0.01);
        if (steps < 2) steps = 2;

        for (int i = 0; i < steps; i++) {
            double angle = (double)i / steps * maxAngle;
            double next  = (double)(i+1) / steps * maxAngle;

            // Spirograph equations
            double x1 = (R - r) * cos(angle) + d * cos((R - r) / r * angle);
            double y1 = (R - r) * sin(angle) - d * sin((R - r) / r * angle);
            double x2 = (R - r) * cos(next)  + d * cos((R - r) / r * next);
            double y2 = (R - r) * sin(next)  - d * sin((R - r) / r * next);

            // Cycle through colors as the curve progresses
            double hue = (double)i / steps;
            double red   = 0.5 + 0.5 * cos(2 * M_PI * (hue + 0.0));
            double green = 0.5 + 0.5 * cos(2 * M_PI * (hue + 0.33));
            double blue  = 0.5 + 0.5 * cos(2 * M_PI * (hue + 0.67));

            cairo_set_source_rgba(cr, red, green, blue, 0.85);
            cairo_set_line_width(cr, 2.5);
            cairo_move_to(cr, WIDTH/2.0 + x1, HEIGHT/2.0 + y1);
            cairo_line_to(cr, WIDTH/2.0 + x2, HEIGHT/2.0 + y2);
            cairo_stroke(cr);
        }

        // Draw a small glowing dot at the pen tip
        double penAngle = maxAngle;
        double px = WIDTH/2.0  + (R-r)*cos(penAngle) + d*cos((R-r)/r*penAngle);
        double py = HEIGHT/2.0 + (R-r)*sin(penAngle) - d*sin((R-r)/r*penAngle);

        // Outer glow
        cairo_set_source_rgba(cr, 1.0, 1.0, 1.0, 0.2);
        cairo_arc(cr, px, py, 12.0, 0, 2*M_PI);
        cairo_fill(cr);
        // Inner dot
        cairo_set_source_rgba(cr, 1.0, 1.0, 1.0, 0.9);
        cairo_arc(cr, px, py, 5.0, 0, 2*M_PI);
        cairo_fill(cr);

        unsigned char* data = cairo_image_surface_get_data(surface);
        fwrite(data, 1, WIDTH * HEIGHT * 4, ffmpeg);
    }

    cairo_destroy(cr);
    cairo_surface_destroy(surface);
    _pclose(ffmpeg);

    printf("Done! output.mp4 written.\n");
    return 0;
}
